{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ejupi-labs-blog",
  "compatibility_date": "2026-07-17",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "blog.ejupilabs.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
